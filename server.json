const WebSocket = require('ws')
const http      = require('http')

const server = http.createServer()
const wss    = new WebSocket.Server({ server })

// ── Etat du serveur ───────────────────────────────────────────
const rooms   = {}  // { room_id: { players: {}, game_state: {}, started: false } }
const clients = {}  // { peer_id: ws }
let   next_id = 2   // peer_id 1 = serveur, clients commencent a 2

// ── Connexion d'un client ─────────────────────────────────────
wss.on('connection', (ws) => {
  const peer_id = next_id++
  clients[peer_id] = ws
  console.log(`[Server] Client connecte : peer_id=${peer_id}`)

  // Envoyer l'ID au client
  ws.send(JSON.stringify({
    type:    'connected',
    peer_id: peer_id
  }))

  ws.on('message', (message) => {
    try {
      const data = JSON.parse(message)
      handle_message(peer_id, data)
    } catch (e) {
      console.error('[Server] Erreur message:', e)
    }
  })

  ws.on('close', () => {
    console.log(`[Server] Client deconnecte : peer_id=${peer_id}`)
    handle_disconnect(peer_id)
    delete clients[peer_id]
  })
})

// ── Gestion des messages ──────────────────────────────────────
function handle_message(peer_id, data) {
  switch (data.type) {

    // Rejoindre une room
    case 'join_room':
      join_room(peer_id, data.room_id, data.player_name, data.team)
      break

    // RPC — relayer a tous les membres de la room
    case 'rpc':
      relay_rpc(peer_id, data)
      break

    // Quitter la room
    case 'leave_room':
      leave_room(peer_id)
      break

    default:
      console.log(`[Server] Message inconnu : ${data.type}`)
  }
}

// ── Rejoindre une room ────────────────────────────────────────
function join_room(peer_id, room_id, player_name, team) {
  if (!rooms[room_id]) {
    rooms[room_id] = { players: {}, started: false }
    console.log(`[Server] Room creee : ${room_id}`)
  }

  const room = rooms[room_id]
  room.players[peer_id] = {
    id:   peer_id,
    name: player_name,
    team: team
  }

  console.log(`[Server] Joueur ${peer_id} (${player_name}) -> room ${room_id}`)

  // Confirmer au joueur
  send_to(peer_id, {
    type:    'room_joined',
    room_id: room_id,
    team:    team
  })

  // Notifier tous les membres
  broadcast_to_room(room_id, {
    type:       'player_joined',
    peer_id:    peer_id,
    player_name: player_name,
    team:       team,
    players:    Object.values(room.players)
  })
}

// ── Relayer un RPC ────────────────────────────────────────────
function relay_rpc(sender_id, data) {
  const room_id = get_player_room(sender_id)
  if (!room_id) return

  if (data.target === 'all') {
    broadcast_to_room(room_id, {
      type:      'rpc',
      sender_id: sender_id,
      method:    data.method,
      args:      data.args
    }, sender_id)
  } else if (data.target === 'all_including_sender') {
    broadcast_to_room(room_id, {
      type:      'rpc',
      sender_id: sender_id,
      method:    data.method,
      args:      data.args
    })
  } else {
    // Envoyer a un peer specifique
    send_to(data.target, {
      type:      'rpc',
      sender_id: sender_id,
      method:    data.method,
      args:      data.args
    })
  }
}

// ── Deconnexion ───────────────────────────────────────────────
function handle_disconnect(peer_id) {
  const room_id = get_player_room(peer_id)
  if (!room_id) return
  leave_room(peer_id)
}

function leave_room(peer_id) {
  const room_id = get_player_room(peer_id)
  if (!room_id || !rooms[room_id]) return

  delete rooms[room_id].players[peer_id]
  console.log(`[Server] Joueur ${peer_id} quitte room ${room_id}`)

  broadcast_to_room(room_id, {
    type:    'player_left',
    peer_id: peer_id
  })

  if (Object.keys(rooms[room_id].players).length === 0) {
    delete rooms[room_id]
    console.log(`[Server] Room ${room_id} detruite`)
  }
}

// ── Utilitaires ───────────────────────────────────────────────
function get_player_room(peer_id) {
  for (const room_id in rooms) {
    if (rooms[room_id].players[peer_id]) return room_id
  }
  return null
}

function send_to(peer_id, data) {
  const ws = clients[peer_id]
  if (ws && ws.readyState === WebSocket.OPEN) {
    ws.send(JSON.stringify(data))
  }
}

function broadcast_to_room(room_id, data, exclude_id = null) {
  if (!rooms[room_id]) return
  for (const pid in rooms[room_id].players) {
    if (parseInt(pid) !== exclude_id) {
      send_to(parseInt(pid), data)
    }
  }
}

const PORT = process.env.PORT || 3001
server.listen(PORT, () => {
  console.log(`[Server] Serveur de jeu demarre sur le port ${PORT}`)
})
